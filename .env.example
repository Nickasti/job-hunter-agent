# ============================================================
#  job-hunter-agent — template variabili d'ambiente
#  Copia in `.env` per l'esecuzione LOCALE.
#  In GitHub Actions queste vanno inserite come "Secrets".
# ============================================================

# --- Gemini (Google AI Studio, free tier) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modello (free tier consigliato). Alternative: gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Telegram Bot ---
# Token da @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID dove ricevere le notifiche (vedi tools/get_telegram_chat_id.py)
TELEGRAM_CHAT_ID=

# --- Gmail OAuth2 (CI-friendly: niente file token, solo refresh token) ---
# Ottenuti da Google Cloud Console (OAuth Client "Desktop app")
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Generato UNA volta in locale con: python tools/generate_gmail_token.py
GMAIL_REFRESH_TOKEN=

# ============================================================
#  Comportamento (tutti opzionali, hanno default sensati)
# ============================================================

# Soglia minima per notificare su Telegram
SCORE_THRESHOLD=55

# Quanti giorni indietro guardare nelle email LinkedIn al primo avvio
LINKEDIN_LOOKBACK_DAYS=2

# Rate limit Gemini: secondi minimi tra due chiamate
GEMINI_MIN_INTERVAL=4.5
# Tentativi max su errore 429 (backoff esponenziale)
GEMINI_MAX_RETRIES=5
# Riusa lo score in cache se il job è stato valutato negli ultimi N giorni
SCORE_CACHE_DAYS=30
# Budget massimo di chiamate Gemini per singolo run (protezione RPD free tier)
GEMINI_MAX_CALLS_PER_RUN=80

# Abilita Playwright per le career page JS-heavy (true/false)
ENABLE_PLAYWRIGHT=true
# Arricchisci i job LinkedIn scaricando la pagina pubblica del job (true/false)
ENABLE_LINKEDIN_ENRICH=true

# Percorso DB (default: storage/jobs.db)
# DB_PATH=storage/jobs.db


# ============================================================
#  PIATTAFORMA WEB MULTI-UTENTE (app/) — variabili aggiuntive
# ============================================================

# --- Database ---
# Locale: lascia vuoto (usa SQLite in ./data/app.db).
# Produzione (Neon/Supabase), driver psycopg v3:
#   postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# --- Sicurezza ---
# Fernet key: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
MASTER_KEY=
# ⚠️ IMPOSTALO FORTE IN PRODUZIONE (se resta al default chiunque puo' forgiare i cookie!)
# python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=cambia-questo-in-produzione
# Bearer token per POST /api/run-cycle (uguale al secret GitHub RUN_CYCLE_TOKEN)
RUN_CYCLE_TOKEN=
# Segreto di validazione del webhook Telegram (forte)
TELEGRAM_WEBHOOK_SECRET=
# Email che puo' vedere /admin (elenco utenti + ultimo accesso)
ADMIN_EMAIL=niko.asti@gmail.com

# --- Gemini: modello di riserva se la quota del primario si esaurisce (per-modello) ---
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# --- URL pubblico dell'app (per OAuth callback + webhook). Niente slash finale ---
PUBLIC_BASE_URL=http://localhost:8000

# --- Google OAuth CONDIVISO (client tipo "Web application") ---
# Redirect URI da registrare in Google: <PUBLIC_BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Telegram bot condiviso (username SENZA @) ---
TELEGRAM_BOT_USERNAME=
